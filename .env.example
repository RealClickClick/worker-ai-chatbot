# Copy this file to .env and fill in your values
# For deployment, use: npx wrangler secret put <NAME>

TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
WORKER_DOMAIN=your-worker.your-subdomain.workers.dev
ADMIN_IDS=your-telegram-user-id-here
BRAVE_API_KEY=your-brave-api-key-here
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key-here
WEBHOOK_SECRET=your-webhook-secret-here
BOT_NAME=MyBot
BOT_DESCRIPTION=You are a friendly AI assistant specialized in helping with coding tasks.
